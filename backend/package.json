{
  "name": "codeverse-backend",
  "version": "1.0.0",
  "description": "CodeVerse - Scalable Coding Platform Backend (Core Modules)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/config/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "mongoose-paginate-v2": "^1.7.4",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@jest/globals": "^29.7.0",
    "mongodb-memory-server": "^9.1.6"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterFramework": [],
    "testTimeout": 30000,
    "verbose": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/seed.js"
    ]
  }
}